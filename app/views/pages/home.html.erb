<!-- Flip Card CSS -->
<style>
  .flip-card {
    background-color: transparent;
    height: 300px;
    perspective: 1000px;
    cursor: pointer;
    border: 1px solid rgba(148, 163, 184, 0.25);
    border-radius: 8px;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.03);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .flip-card:hover {
    transform: translateY(-3px) scale(1.01);
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.14);
    animation: card-bounce 0.45s ease-in-out;
  }

  @keyframes card-bounce {
    0%, 100% { transform: translateY(-3px) scale(1.01); }
    50% { transform: translateY(-6px) scale(1.015); }
  }

  .education-card {
    height: 145px;
  }

  .work-card {
    height: 140px;
  }

  .about-card {
    height: 300px;
    max-width: 300px;
    margin: 0 auto;
  }

  @media (max-width: 991.98px) {
    .about-card {
      max-width: 100%;
      height: 320px;
    }
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  .work-grid .col-6 {
    width: 100%;
  }

  .flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.6s;
    transform-style: preserve-3d;
  }

  .flip-card.flipped .flip-card-inner {
    transform: rotateY(180deg);
  }

  .flip-card-front, .flip-card-back {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(15, 23, 42, 0.18);
  }

  .flip-card-front img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: var(--image-fit, cover);
    object-position: var(--image-position, center);
    padding: var(--image-padding, 0);
    box-sizing: border-box;
    transform: scale(var(--image-scale, 1));
    transform-origin: center center;
  }

  .flip-card-back {
    background-color: #343a40;
    color: white;
    transform: rotateY(180deg);
    padding: 20px;
    overflow-y: auto;
  }

  .project-carousel {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .project-carousel-nav {
    border: none;
    background: #111827;
    color: white;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    cursor: pointer;
    flex-shrink: 0;
  }

  .project-carousel-viewport {
    flex: 1;
    overflow: hidden;
    border-radius: 16px;
  }

  .project-carousel-track {
    display: flex;
    transition: transform 0.3s ease;
  }

  .project-card {
    min-width: 100%;
    padding: 0.25rem;
  }

  .project-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
  }

  .project-card-image {
    height: 180px;
    background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #64748b;
    font-weight: 600;
    border-bottom: 1px solid #e5e7eb;
  }

  .project-card-content {
    padding: 1rem 1.1rem 1.2rem;
  }

  .project-card-content h5 {
    margin-bottom: 0.35rem;
  }

  .project-carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0.9rem;
  }

  .project-carousel-dot {
    width: 10px;
    height: 10px;
    border: none;
    border-radius: 50%;
    background: #cbd5e1;
    padding: 0;
    cursor: pointer;
  }

  .project-carousel-dot.active {
    background: #111827;
  }

  .bento-section {
    background: #f3f1f9;
  }

  .bento-section-title {
    border-bottom: 1px solid #DDD9EA;
    padding-bottom: 0.55rem;
    margin-bottom: 1.25rem;
  }

  .bento-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: 1fr;
  }

  .bento-tile {
    min-height: 100px;
    background: #ffffff;
    border: 1px solid #DDD9EA;
    border-radius: 14px;
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .bento-tile:hover {
    transform: translateY(-3px);
    border-color: #cfc8de;
  }

  .bento-tile-icon {
    color: #534AB7;
    font-size: 20px;
    margin-bottom: 10px;
  }

  .bento-tile-title {
    margin: 0;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.35;
    color: #1f1a32;
  }

  .bento-tile-note {
    margin: 6px 0 0;
    font-size: 13px;
    line-height: 1.5;
    color: #6b6885;
  }

  .bento-tile-featured {
    background: #2D2560;
    border: none;
    color: #ffffff;
  }

  .bento-tile-featured .bento-tile-icon {
    color: #CECBF6;
    font-size: 26px;
    margin-bottom: 10px;
  }

  .bento-tile-featured .bento-tile-title {
    color: #ffffff;
  }

  .bento-tile-featured .bento-tile-note {
    color: #AFA9EC;
  }

  @media (min-width: 992px) {
    .bento-grid {
      grid-template-columns: 1.5fr 1fr 1fr;
      grid-auto-rows: minmax(120px, auto);
    }

    .bento-grid .bento-tile:first-child {
      grid-column: 1;
      grid-row: 1 / span 2;
    }

    .bento-grid .bento-tile:nth-child(2) {
      grid-column: 2;
      grid-row: 1;
    }

    .bento-grid .bento-tile:nth-child(3) {
      grid-column: 3;
      grid-row: 1;
    }

    .bento-grid .bento-tile:nth-child(4) {
      grid-column: 2;
      grid-row: 2;
    }

    .bento-grid .bento-tile:nth-child(5) {
      grid-column: 3;
      grid-row: 2;
    }

    .bento-grid .bento-tile:last-child {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 768px) and (max-width: 991.98px) {
    .bento-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .bento-grid .bento-tile:first-child {
      grid-column: 1 / -1;
      grid-row: auto;
    }

    .bento-grid .bento-tile:last-child {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 767.98px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }

    .bento-grid .bento-tile:first-child,
    .bento-grid .bento-tile:last-child {
      grid-column: auto;
      grid-row: auto;
    }
  }

  #about,
  #interests,
  #projects,
  #contact {
    scroll-margin-top: 100px;
  }

  body {
    margin: 0;
    padding: 0;
  }

  .navbar-gradient {
    background: linear-gradient(135deg, #2d1b69 0%, #1a0f3d 25%, #3d1a52 50%, #1a0f3d 75%, #2d1b69 100%);
    background-size: 400% 400%;
    animation: hero-gradient 15s ease infinite;
    z-index: 1031;
  }

  .navbar-gradient::after {
    content: "";
    position: fixed;
    inset: 0;
    top: 0;
    background: radial-gradient(circle at 20% 50%, rgba(147, 51, 234, 0.1), transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(168, 85, 247, 0.08), transparent 50%);
    pointer-events: none;
    z-index: 1030;
  }

  .navbar-gradient .navbar-brand,
  .navbar-gradient .nav-link {
    position: relative;
    z-index: 1031;
  }

  .hero-section {
    background: linear-gradient(135deg, #2d1b69 0%, #1a0f3d 25%, #3d1a52 50%, #1a0f3d 75%, #2d1b69 100%);
    background-size: 400% 400%;
    animation: hero-gradient 15s ease infinite;
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 20% 50%, rgba(147, 51, 234, 0.1), transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(168, 85, 247, 0.08), transparent 50%);
    pointer-events: none;
  }

  .hero-section > * {
    position: relative;
    z-index: 1;
  }

  @keyframes hero-gradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
</style>

