                </div>
              </div>
            </div>
          </div>
          <div class="col-6">
            <div class="flip-card work-card" onclick="this.classList.toggle('flipped')">
              <div class="flip-card-inner">
                <div class="flip-card-front">
                  <%= image_tag "Cardinal.png", alt: "Company 3" %>
                </div>
                <div class="flip-card-back">
                  <h6>Intern</h6>
                  <p class="text-white-50 small">Cardinal Health · Summer 2018</p>
                </div>
              </div>
            </div>
          </div>
          <div class="col-6">
            <div class="flip-card work-card" onclick="this.classList.toggle('flipped')">
              <div class="flip-card-inner">
                <div class="flip-card-front">
                  <%= image_tag "Reynolds.png", alt: "Company 4" %>
                </div>
                <div class="flip-card-back">
                  <h6>Intern</h6>
                  <p class="text-white-50 small">Reynolds American · Summer 2017</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Education Column -->
      <div class="col-4">
        <h2 class="fw-bold border-bottom pb-2 mb-4">Education</h2>
        <div class="row g-2">
          <div class="col-12">
            <div class="flip-card education-card" onclick="this.classList.toggle('flipped')">
              <div class="flip-card-inner">
                <div class="flip-card-front">
                  <%= image_tag asset_path("KelloggMBA.jpg"), alt: "School 1" %>
                </div>
                <div class="flip-card-back">
                  <h6>Masters Degree</h6>
                  <p class="text-white-50 small">Kellogg School of Management · 2026</p>
                  <p class="small">Major(s): Finance & Marketing</p>
