              </div>
            </div>
          </div>
          <div class="col-12">
            <div class="flip-card education-card" onclick="this.classList.toggle('flipped')">
              <div class="flip-card-inner">
                <div class="flip-card-front">
                 <img src="https://logos-world.net/wp-content/uploads/2021/09/The-Ohio-State-University-Logo.png" alt="School 2">

                </div>
