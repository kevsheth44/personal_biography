            <a href="https://example.com/" target="_blank" rel="noopener noreferrer" class="project-card-link">
              <div class="project-card-image" style="padding: 0; background: none; overflow: hidden;">
                <%= image_tag "Coming Soon Image.png", alt: "Group Poop", style: "width: 100%; height: 100%; object-fit: cover; object-position: center;" %>
              </div>
              <div class="project-card-content">
